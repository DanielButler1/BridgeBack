# OpenAI Responses and Realtime APIs (server-only; never expose with NEXT_PUBLIC_).
OPENAI_API_KEY=
# Keep model selection server-side so a future supported Realtime model can be adopted without client changes.
OPENAI_REALTIME_MODEL=gpt-realtime-2.1

# Convex deployment. Run `npx convex dev` to provision these values.
NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOYMENT=

# Clerk application and Convex JWT template named `convex`.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_JWT_ISSUER_DOMAIN=

# Synthetic Build Week judge identities. Never put real pupil accounts here.
DEMO_AUTH_ENABLED=false
DEMO_TEACHER_CLERK_USER_ID=
DEMO_PUPIL_CLERK_USER_ID=
